
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
    shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Organization {
    id String @unique
    name String

    deployResults DeployResult[]
}

model DeployResult {
    id String @unique
    status       String

    createdBy   String
    createdByName String

    startDate    DateTime
    endDate DateTime
    
    numberTestsCompleted Int
    numberTestsTotal Int
    numberTestErrors Int

    numberComponentsDeployed Int
    numberComponentsTotal Int
    numberComponentErrors Int

    checkOnly Boolean

    deployUrl String

    componentSuccesses DeployMessageSuccess[]
    componentFailures DeployMessageFailure[]
    runTestSuccesses RunTestSuccess[]
    runTestFailures RunTestFailure[]

    organizationId String
    Organization Organization @relation(fields: [organizationId], references: [id])
}

model DeployMessageSuccess {
    id String @default(uuid()) @unique

    fullName String
    componentType String

    changed Boolean
    created Boolean
    deleted Boolean

    deployResultId String
    DeployResult DeployResult @relation(fields: [deployResultId], references: [id])
}

model DeployMessageFailure {
    id String @default(uuid()) @unique

    fullName String
    componentType String

    changed Boolean
    created Boolean
    deleted Boolean

    columnNumber Int
    lineNumber Int

    problem String
    problemType String

    deployResultId String
    DeployResult DeployResult @relation(fields: [deployResultId], references: [id])
}

model RunTestSuccess {
    id String @unique

    className String
    methodName String
    namespace String

    time Int

    deployResultId String
    DeployResult DeployResult @relation(fields: [deployResultId], references: [id])
}

model RunTestFailure {
    id String @unique

    className String
    methodName String
    namespace String

    message String
    stackTrace String

    time Int
    type String

    deployResultId String
    DeployResult DeployResult @relation(fields: [deployResultId], references: [id])
}
