
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Organization {
    id String @unique
    name String

    deployments Deployment[]
}

model Deployment {
    id String @unique
    status       String

    createdBy   String
    createdByName String

    startDate    DateTime
    endDate DateTime
    
    numberTestsCompleted Int
    numberTestsTotal Int
    numberTestErrors Int

    numberComponentsDeployed Int
    numberComponentsTotal Int
    numberComponentErrors Int

    checkOnly Boolean

    deployUrl String

    componentSuccesses DeployComponentSuccess[]
    componentFailures DeployComponentFailure[]
    testSuccesses DeployTestSuccess[]
    testFailures DeployTestFailure[]

    organizationId String
    Organization Organization @relation(fields: [organizationId], references: [id])
}

model DeployComponentSuccess {
    id String @default(uuid()) @unique

    fullName String
    componentType String

    changed Boolean
    created Boolean
    deleted Boolean

    deploymentId String
    Deployment Deployment @relation(fields: [deploymentId], references: [id])
}

model DeployComponentFailure {
    id String @default(uuid()) @unique

    fullName String
    componentType String

    changed Boolean
    created Boolean
    deleted Boolean

    columnNumber Int
    lineNumber Int

    problem String
    problemType String

    deploymentId String
    Deployment Deployment @relation(fields: [deploymentId], references: [id])
}

model DeployTestSuccess {
    id String @unique

    className String
    methodName String
    namespace String?

    time Int

    deploymentId String
    Deployment Deployment @relation(fields: [deploymentId], references: [id])
}

model DeployTestFailure {
    id String @unique

    className String
    methodName String
    namespace String?

    message String
    stackTrace String

    time Int
    type String

    deploymentId String
    Deployment Deployment @relation(fields: [deploymentId], references: [id])
}
